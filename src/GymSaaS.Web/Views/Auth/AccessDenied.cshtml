@{
    ViewData["Title"] = "Acceso Denegado";
    Layout = "~/Views/Shared/_LayoutMD3.cshtml";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="glass-panel p-5 text-center border-danger border-opacity-25">
            <i class="bi bi-shield-lock-fill text-danger" style="font-size: 3rem;"></i>
            <h2 class="brand-font text-white mt-3">Acceso Denegado</h2>
            <p class="text-secondary">
                Tu usuario no tiene permiso para ver esta sección. Si creés que es un error, pedile a un administrador
                que revise tu rol en <strong>Personal</strong>.
            </p>
            <a asp-controller="Dashboard" asp-action="Index" class="btn-md3 btn-md3-primary mt-3">
                <i class="bi bi-house-door-fill me-1"></i> Volver al Dashboard
            </a>
        </div>
    </div>
</div>
