@model GymSaaS.Domain.Entities.Tenant
@{
    ViewData["Title"] = "Branding del Gimnasio";
    Layout = "_LayoutMD3";
}

<div class="glass-panel mb-4">
    <h4 class="brand-font mb-1" style="color: var(--md-sys-color-primary);">
        <i class="bi bi-palette-fill me-2"></i>BRANDING PERSONALIZADO
    </h4>
    <p class="text-secondary small mb-0">
        Personaliza la apariencia de tu panel y portal de socios con tu identidad de marca.
    </p>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert mb-4" style="background: rgba(10,255,10,0.08); border: 1px solid var(--md-sys-color-tertiary); color: var(--md-sys-color-tertiary); border-radius: 12px;">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
    </div>
}

<div class="row g-4">
    <!-- FORMULARIO -->
    <div class="col-lg-7">
        <div class="glass-panel">
            <form asp-action="Branding" method="post" id="brandingForm">
                @Html.AntiForgeryToken()

                <!-- NOMBRE DISPLAY -->
                <div class="mb-4">
                    <label class="form-label text-secondary small text-uppercase fw-bold">
                        <i class="bi bi-type me-1"></i> Nombre del Gimnasio (Sidebar)
                    </label>
                    <input type="text"
                           name="gymNombreDisplay"
                           id="inputNombre"
                           class="form-control bg-dark border-secondary text-white"
                           placeholder="ej: IRON GYM"
                           value="@Model.GymNombreDisplay"
                           maxlength="30"
                           style="border-radius: 10px;" />
                    <small class="text-secondary opacity-75">
                        Si se deja vacío, se usará el nombre completo del gimnasio: <strong class="text-white">@Model.Name</strong>
                    </small>
                </div>

                <!-- URL DEL LOGO -->
                <div class="mb-4">
                    <label class="form-label text-secondary small text-uppercase fw-bold">
                        <i class="bi bi-image me-1"></i> URL del Logo
                    </label>
                    <input type="url"
                           name="logoUrl"
                           id="inputLogoUrl"
                           class="form-control bg-dark border-secondary text-white"
                           placeholder="https://ejemplo.com/mi-logo.png"
                           value="@Model.LogoUrl"
                           style="border-radius: 10px;" />
                    <small class="text-secondary opacity-75">
                        Pegá la URL pública de tu logo (PNG/SVG con fondo transparente recomendado). Tamaño ideal: 200×60px.
                    </small>
                </div>

                <!-- COLOR PRIMARIO -->
                <div class="mb-4">
                    <label class="form-label text-secondary small text-uppercase fw-bold">
                        <i class="bi bi-droplet-fill me-1"></i> Color Primario
                    </label>
                    <div class="d-flex align-items-center gap-3">
                        <input type="color"
                               name="colorPrimario"
                               id="inputColor"
                               value="@(string.IsNullOrEmpty(Model.ColorPrimario) ? "#00f3ff" : Model.ColorPrimario)"
                               style="width: 60px; height: 48px; border-radius: 10px; border: 1px solid rgba(255,255,255,0.15); cursor: pointer; background: transparent; padding: 4px;" />
                        <div>
                            <input type="text"
                                   id="inputColorHex"
                                   class="form-control bg-dark border-secondary text-white"
                                   style="width: 120px; border-radius: 10px; font-family: monospace;"
                                   maxlength="7"
                                   placeholder="#00f3ff"
                                   value="@(string.IsNullOrEmpty(Model.ColorPrimario) ? "#00f3ff" : Model.ColorPrimario)" />
                            <small class="text-secondary opacity-75 d-block mt-1">Valor HEX</small>
                        </div>
                        <div>
                            <button type="button" class="btn btn-sm" id="btnResetColor"
                                    style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.15); color: #ccc; border-radius: 8px;">
                                <i class="bi bi-arrow-counterclockwise"></i> Reset
                            </button>
                        </div>
                    </div>
                    <small class="text-secondary opacity-75 mt-1 d-block">
                        Este color se aplica a botones, acentos, el sidebar y el portal de socios.
                    </small>
                </div>

                <div class="d-flex gap-3 mt-4">
                    <button type="submit" class="btn-md3 btn-md3-primary flex-grow-1 py-3">
                        <i class="bi bi-floppy-fill me-2"></i> GUARDAR BRANDING
                    </button>
                    <button type="button" id="btnLimpiar" class="btn py-3 px-4"
                            style="background: rgba(255,42,42,0.1); border: 1px solid rgba(255,42,42,0.3); color: #ff6b6b; border-radius: 100px;">
                        <i class="bi bi-trash3"></i>
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- PREVIEW EN TIEMPO REAL -->
    <div class="col-lg-5">
        <div class="glass-panel" style="position: sticky; top: 20px;">
            <h6 class="text-secondary text-uppercase small mb-3 fw-bold">
                <i class="bi bi-eye me-1"></i> Vista Previa
            </h6>

            <!-- Preview del Sidebar -->
            <div style="background: rgba(10,10,15,0.95); border-radius: 16px; padding: 16px; border: 1px solid rgba(255,255,255,0.08); margin-bottom: 16px;">
                <div class="d-flex align-items-center gap-2 mb-3 pb-2" style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                    <div id="previewLogoContainer">
                        <i id="previewIcon" class="bi bi-cpu-fill fs-3" style="color: var(--preview-color, #00f3ff); filter: drop-shadow(0 0 5px var(--preview-color, #00f3ff));"></i>
                    </div>
                    <span id="previewNombre" class="fw-bold text-white" style="font-family: 'Orbitron', sans-serif; text-transform: uppercase; letter-spacing: 1px; font-size: 0.9rem;">
                        @(string.IsNullOrEmpty(Model.GymNombreDisplay) ? (Model.GymNombreDisplay ?? Model.Name ?? "GYMVO") : Model.GymNombreDisplay)
                    </span>
                </div>
                @foreach (var item in new[] {
                    ("bi-grid-fill", "Dashboard", true),
                    ("bi-qr-code-scan", "Control de Acceso", false),
                    ("bi-people-fill", "Socios", false),
                    ("bi-palette-fill", "Branding", false)
                })
                {
                    <div class="d-flex align-items-center gap-2 mb-2 px-2 py-1"
                         style="border-radius: 50px; @(item.Item3 ? "background: var(--preview-color-bg, rgba(0,243,255,0.15));" : "")">
                        <i class="bi @item.Item1 small" style="@(item.Item3 ? "color: var(--preview-color, #00f3ff);" : "color: rgba(255,255,255,0.4);")"></i>
                        <span style="font-size: 0.8rem; @(item.Item3 ? "color: var(--preview-color, #00f3ff); font-weight: 700;" : "color: rgba(255,255,255,0.4);")">
                            @item.Item2
                        </span>
                    </div>
                }
            </div>

            <!-- Preview del color -->
            <div class="d-flex gap-2">
                <div id="previewColorBtn"
                     style="flex: 1; padding: 10px 16px; border-radius: 100px; border: 1px solid var(--preview-color, #00f3ff); color: var(--preview-color, #00f3ff); font-size: 0.8rem; font-weight: 700; text-align: center; letter-spacing: 1px; box-shadow: 0 0 8px var(--preview-color, #00f3ff);">
                    BTN PRIMARIO
                </div>
                <div id="previewDot" style="width: 42px; height: 42px; border-radius: 50%; background: var(--preview-color, #00f3ff); box-shadow: 0 0 15px var(--preview-color, #00f3ff); opacity: 0.8;"></div>
            </div>

            <!-- Preview logo -->
            <div id="previewLogoImg" class="text-center mt-3" style="display:none;">
                <p class="text-secondary small mb-1">Logo cargado:</p>
                <img id="previewImg" src="" alt="Preview Logo"
                     style="max-height: 60px; max-width: 180px; object-fit: contain; border-radius: 8px; border: 1px solid rgba(255,255,255,0.1); padding: 8px; background: rgba(255,255,255,0.03);" />
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Sincroniza el picker de color con el input hex y la preview
    const inputColor  = document.getElementById('inputColor');
    const inputHex    = document.getElementById('inputColorHex');
    const inputNombre = document.getElementById('inputNombre');
    const inputLogoUrl = document.getElementById('inputLogoUrl');

    // Elementos de preview
    const previewNombre    = document.getElementById('previewNombre');
    const previewColorBtn  = document.getElementById('previewColorBtn');
    const previewDot       = document.getElementById('previewDot');
    const previewIcon      = document.getElementById('previewIcon');
    const previewLogoImg   = document.getElementById('previewLogoImg');
    const previewImg       = document.getElementById('previewImg');
    const previewLogoContainer = document.getElementById('previewLogoContainer');

    function applyColor(hex) {
        // Valida que sea un color hex válido
        if (!/^#[0-9A-Fa-f]{6}$/.test(hex)) return;

        // Preview local (sin tocar el CSS global)
        document.documentElement.style.setProperty('--preview-color', hex);
        // Calculamos un RGBA para el fondo del item activo
        const r = parseInt(hex.slice(1,3),16);
        const g = parseInt(hex.slice(3,5),16);
        const b = parseInt(hex.slice(5,7),16);
        document.documentElement.style.setProperty('--preview-color-bg', `rgba(${r},${g},${b},0.15)`);

        previewColorBtn.style.borderColor = hex;
        previewColorBtn.style.color = hex;
        previewColorBtn.style.boxShadow = `0 0 8px ${hex}`;
        previewDot.style.background = hex;
        previewDot.style.boxShadow = `0 0 15px ${hex}`;
        previewIcon.style.color = hex;
        previewIcon.style.filter = `drop-shadow(0 0 5px ${hex})`;

        inputColor.value = hex;
        inputHex.value = hex;
    }

    // Picker de color → hex input + preview
    inputColor.addEventListener('input', () => {
        applyColor(inputColor.value);
    });

    // Hex input → picker + preview
    inputHex.addEventListener('input', () => {
        let val = inputHex.value;
        if (!val.startsWith('#')) val = '#' + val;
        if (/^#[0-9A-Fa-f]{6}$/.test(val)) {
            applyColor(val);
        }
    });

    // Nombre → preview sidebar
    inputNombre.addEventListener('input', () => {
        const n = inputNombre.value.trim();
        previewNombre.textContent = n || '@(Model.Name ?? "GYMVO")';
    });

    // URL Logo → preview
    let logoTimeout;
    inputLogoUrl.addEventListener('input', () => {
        clearTimeout(logoTimeout);
        const url = inputLogoUrl.value.trim();
        if (!url) {
            previewLogoImg.style.display = 'none';
            previewIcon.style.display = '';
            return;
        }
        logoTimeout = setTimeout(() => {
            previewImg.src = url;
            previewImg.onload = () => {
                previewLogoImg.style.display = 'block';
                previewIcon.style.display = 'none';
            };
            previewImg.onerror = () => {
                previewLogoImg.style.display = 'none';
                previewIcon.style.display = '';
            };
        }, 600);
    });

    // Mostrar logo si ya existe al cargar
    const existingLogo = '@(Model.LogoUrl ?? "")';
    if (existingLogo) {
        previewImg.src = existingLogo;
        previewImg.onload = () => {
            previewLogoImg.style.display = 'block';
            previewIcon.style.display = 'none';
        };
    }

    // Reset color
    document.getElementById('btnResetColor').addEventListener('click', () => {
        applyColor('#00f3ff');
    });

    // Limpiar todo
    document.getElementById('btnLimpiar').addEventListener('click', () => {
        if (confirm('¿Limpiar todo el branding y volver a los valores por defecto?')) {
            document.querySelector('[name="logoUrl"]').value = '';
            document.querySelector('[name="gymNombreDisplay"]').value = '';
            applyColor('#00f3ff');
            previewLogoImg.style.display = 'none';
            previewIcon.style.display = '';
            previewNombre.textContent = '@(Model.Name ?? "GYMVO")';
        }
    });

    // Inicializar preview con valores actuales
    applyColor(inputColor.value);
</script>
}
