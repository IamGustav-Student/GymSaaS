@{
    ViewData["Title"] = "Pago Rechazado";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Pago Rechazado - Gymvo SaaS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&family=Rajdhani:wght@300;500;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --neon-red: #ff2b2b;
            --bg-dark: #050505;
            --card-bg: rgba(20, 20, 20, 0.6);
        }

        body {
            background-color: var(--bg-dark);
            background-image: radial-gradient(circle at 85% 30%, rgba(255, 43, 43, 0.06) 0%, transparent 25%);
            color: #e0e0e0;
            font-family: 'Rajdhani', sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem 0;
        }

        .brand-font {
            font-family: 'Orbitron', sans-serif;
        }

        .result-card {
            max-width: 520px;
            width: 100%;
            background: var(--card-bg);
            backdrop-filter: blur(12px);
            border: 1px solid #333;
            border-top: 4px solid var(--neon-red);
            border-radius: 16px;
            padding: 3rem 2rem;
            text-align: center;
        }

        .result-icon {
            font-size: 4rem;
            color: var(--neon-red);
            text-shadow: 0 0 20px rgba(255, 43, 43, 0.5);
            margin-bottom: 1rem;
        }

        .btn-cyber {
            padding: 12px 24px;
            text-transform: uppercase;
            font-weight: 700;
            letter-spacing: 1px;
            border-radius: 4px;
            font-family: 'Orbitron', sans-serif;
            font-size: 0.9rem;
            border: 1px solid var(--neon-red);
            color: var(--neon-red);
            background: transparent;
            text-decoration: none;
            display: inline-block;
            transition: all 0.3s ease;
        }

            .btn-cyber:hover {
                background: var(--neon-red);
                color: black;
                box-shadow: 0 0 15px var(--neon-red);
            }
    </style>
</head>
<body>
    <div class="result-card">
        <div class="result-icon"><i class="bi bi-x-circle-fill"></i></div>
        <h1 class="brand-font text-white mb-3" style="font-size: 1.8rem;">PAGO RECHAZADO</h1>
        <p class="lead text-secondary mb-4">
            No pudimos procesar tu pago. Podés intentar nuevamente o elegir otro medio de pago.
        </p>
        <a asp-controller="Subscription" asp-action="Pricing" class="btn-cyber">VOLVER A INTENTAR</a>
    </div>
</body>
</html>
