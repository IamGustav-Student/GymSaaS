@using GymSaaS.SharedUI.Services
@inject NavigationService NavService

<div class="sidebar">
    <div class="sidebar-logo">
        <span class="logo-icon">🏋️</span>
        <span class="logo-text">Gymvo Hub</span>
    </div>

    <nav class="sidebar-nav">
        <button class="nav-item @(NavService.CurrentView == AppView.Dashboard ? "active" : "")" 
                @onclick="() => NavService.NavigateTo(AppView.Dashboard)">
            <span class="nav-icon">📊</span>
            <span class="nav-text">Dashboard</span>
        </button>

        <button class="nav-item @(NavService.CurrentView == AppView.SocioList || NavService.CurrentView == AppView.SocioDetails || NavService.CurrentView == AppView.SocioForm ? "active" : "")" 
                @onclick="() => NavService.NavigateTo(AppView.SocioList)">
            <span class="nav-icon">👥</span>
            <span class="nav-text">Socios</span>
        </button>

        <button class="nav-item @(NavService.CurrentView == AppView.PlansList || NavService.CurrentView == AppView.PlansForm ? "active" : "")" 
                @onclick="() => NavService.NavigateTo(AppView.PlansList)">
            <span class="nav-icon">📋</span>
            <span class="nav-text">Planes</span>
        </button>

        <button class="nav-item @(NavService.CurrentView == AppView.Agenda ? "active" : "")" 
                @onclick="() => NavService.NavigateTo(AppView.Agenda)">
            <span class="nav-icon">📅</span>
            <span class="nav-text">Agenda</span>
        </button>

        <div class="nav-divider"></div>

        <button class="nav-item logout" @onclick="HandleLogout">
            <span class="nav-icon">🚪</span>
            <span class="nav-text">Salir</span>
        </button>
    </nav>
</div>

@code {
    protected override void OnInitialized()
    {
        NavService.OnNavigationChanged += StateHasChanged;
    }

    private void HandleLogout()
    {
        // Por ahora refrescamos forzosamente para limpiar sesión (F5 manual simulado)
        // En el futuro inyectaremos IApiService para limpiar el token
    }

    public void Dispose()
    {
        NavService.OnNavigationChanged -= StateHasChanged;
    }
}
